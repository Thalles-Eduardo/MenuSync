# Porta do host para o Postgres do docker-compose. So defina se a 5432 ja
# estiver ocupada na sua maquina (lembre de refletir no DATABASE_URL).
# POSTGRES_PORT=5432
DATABASE_URL="postgresql://menusync:menusync@localhost:5432/menusync?schema=public"
# Chave da Resend (painel > API Keys).
RESEND_API_KEY=""
# Endereco PURO, sem "Nome <...>" — o nome de exibicao vai em COUPON_FROM_NAME.
#
# SANDBOX: `onboarding@resend.dev` funciona sem verificar dominio nenhum, mas a
# Resend so ENTREGA para o e-mail dono da conta; qualquer outro destinatario
# volta como erro e a API responde 502. Isso e limitacao do sandbox, nao defeito.
# Para entregar a qualquer endereco, verifique um dominio proprio no painel e
# troque este valor por algo como cupom@seudominio.com.
COUPON_FROM_EMAIL="onboarding@resend.dev"
COUPON_FROM_NAME="MenuSync"
